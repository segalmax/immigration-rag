      "link": null,
      "locked": false,
      "text": "1. frs + nfr + out of scope\n2. api\n3. entities\n4. data flow\n5. HL design\n6. deep dives",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. frs + nfr + out of scope\n2. api\n3. entities\n4. data flow\n5. HL design\n6. deep dives",
