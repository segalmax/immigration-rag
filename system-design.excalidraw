    },
    {
      "id": "VFShS9ICzhGoWaCySk2Li",
      "type": "text",
      "x": 1287.725416890658,
      "y": -3994.634869302022,
      "width": 627.9996337890625,
      "height": 850,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a5",
      "roundness": null,
      "seed": 1764115488,
      "version": 1195,
      "versionNonce": 1646136559,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774563041876,
      "link": null,
      "locked": false,
      "text": "- KB dashboard:\n    - show the dashboard:\n        GET /  -> html file\n    - browse the actual files in kb:\n        GET /browse -> html\n    - render a specific file page (will show s3 paths later)\n        GET /browse/<local path>\n\n- upload a file:\n    1. get the presigned url:\n        POST v1/uploads/presign\n        {\n            filename: base_fn.md\n            content_type:text/md\n        }\n        response:\n        {\n            bucket:kb-rag...,\n            key: uploads/chapter1.md\n            url: .... (s3 endpoint)\n        }\n    2. client calls s3 (not our endpoint ):\n        PUT aws-host.com/uploads/chapter1.md <signature hash>\n\n- ask question:\n    POST v1/ask\n        content-type: json {\n            question: \"how to immigrate\"\n        }\n        response: \n       {answer: \"immig steps are: .... sources:\",\n        sources: [link1, link2,..]}\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- KB dashboard:\n    - show the dashboard:\n        GET /  -> html file\n    - browse the actual files in kb:\n        GET /browse -> html\n    - render a specific file page (will show s3 paths later)\n        GET /browse/<local path>\n\n- upload a file:\n    1. get the presigned url:\n        POST v1/uploads/presign\n        {\n            filename: base_fn.md\n            content_type:text/md\n        }\n        response:\n        {\n            bucket:kb-rag...,\n            key: uploads/chapter1.md\n            url: .... (s3 endpoint)\n        }\n    2. client calls s3 (not our endpoint ):\n        PUT aws-host.com/uploads/chapter1.md <signature hash>\n\n- ask question:\n    POST v1/ask\n        content-type: json {\n            question: \"how to immigrate\"\n        }\n        response: \n       {answer: \"immig steps are: .... sources:\",\n        sources: [link1, link2,..]}\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
