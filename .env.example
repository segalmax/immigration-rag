# ARCHITECTURE: all os.environ["..."] calls in app.py, worker.py, and src/ read from here.
# Loaded by systemd via EnvironmentFile=. On local dev, loaded by python-dotenv at startup.
# ⚠️ CRITICAL: Never commit .env to git — it contains AWS credentials/endpoints.
# Step 1: cp .env.example .env  →  Step 2: fill real values  →  Step 3: start services.

# ⏭️ SKIP: AWS_REGION — standard AWS region string, same for all services below.
AWS_REGION=us-east-1

# 🎯 FOCUS: these 4 vars wire the app to your specific AWS resources.
# Wrong value → crash on first AWS API call (fail-fast, no silent fallbacks).
S3_BUCKET=your-bucket-name
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/your-queue-name
OS_HOST=your-collection-id.us-east-1.aoss.amazonaws.com
OS_INDEX=immigration-index

# ⚠️ CRITICAL: model IDs must match what's enabled in your Bedrock account.
# Titan v2 produces 1024-dim vectors — must match the index mapping in opensearch/index_schema.json.
TITAN_EMBED_MODEL=amazon.titan-embed-text-v2:0
CLAUDE_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Used only when running `python app.py` directly (not gunicorn).
# gunicorn ignores PORT and uses --bind 0.0.0.0:5000 from the service file instead.
PORT=5000
