# Copy this to .env and fill in your values. Never commit .env to git.

# AWS
AWS_REGION=us-east-1

# S3
S3_BUCKET=rag-class-docs-<team>

# SQS
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account-id>/rag-class-docs-queue-<team>

# OpenSearch
OS_HOST=<opensearch-domain-endpoint>     # e.g. search-xxx.us-east-1.es.amazonaws.com
OS_INDEX=uscis-policy

# Bedrock models
CLAUDE_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
TITAN_EMBED_MODEL=amazon.titan-embed-text-v1

# App
PORT=5000
