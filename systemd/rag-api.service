[Unit]
Description=Immigration RAG — Flask API
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/immigration-rag
EnvironmentFile=/home/ubuntu/immigration-rag/.env
ExecStart=/home/ubuntu/immigration-rag/.venv/bin/gunicorn app:app --bind 0.0.0.0:5000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
