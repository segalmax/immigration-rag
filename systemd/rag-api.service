[Unit]
Description=USCIS RAG Flask API
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/immigration-rag
EnvironmentFile=/home/ubuntu/immigration-rag/.env
ExecStart=/home/ubuntu/immigration-rag/venv/bin/gunicorn \
    --workers 2 \
    --bind 0.0.0.0:5000 \
    --timeout 120 \
    app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
